generator client {
  provider     = "prisma-client"
  output       = "../prisma/client"
  moduleFormat = "cjs"
  engineType   = "client"
}

datasource db {
  provider = "postgresql"
}

model Aircraft {
  id                    String        @id @default(uuid()) @db.Uuid
  type                  String        @db.VarChar(4)
  registration          String        @unique
  selcal                String
  livery                String
  currentState          AircraftState @default(idle)
  operatorId            String?       @db.Uuid
  baseAirportId         String?       @db.Uuid
  lastAirportId         String?       @db.Uuid
  lastAirportUpdatedAt  DateTime?
  lastParkingPositionId String?       @db.Uuid

  operator            Operator?            @relation(fields: [operatorId], references: [id])
  baseAirport         Airport?             @relation("AircraftBaseAirport", fields: [baseAirportId], references: [id], onDelete: SetNull)
  lastAirport         Airport?             @relation("AircraftLastAirport", fields: [lastAirportId], references: [id], onDelete: SetNull)
  lastParkingPosition ParkingPosition?     @relation("AircraftLastParkingPosition", fields: [lastParkingPositionId], references: [id], onDelete: SetNull)
  flight              Flight[]
  repositions         AircraftReposition[]

  @@map("aircraft")
}

model Airport {
  id        String    @id @default(uuid()) @db.Uuid
  icaoCode  String    @unique @db.VarChar(4)
  iataCode  String    @unique @db.VarChar(3)
  name      String
  city      String
  country   String
  timezone  String
  continent Continent
  location  Json      @default("{\"latitude\": 0, \"longitude\": 0}")
  shape     Json?

  airportsOnFlights         AirportsOnFlights[]
  diversion                 Diversion[]
  terminals                 Terminal[]
  runways                   Runway[]
  baseForAircraft           Aircraft[]           @relation("AircraftBaseAirport")
  lastForAircraft           Aircraft[]           @relation("AircraftLastAirport")
  homeForUsers              User[]               @relation("UserHomeAirport")
  lastForUsers              User[]               @relation("UserLastAirport")
  departureForTravels       UserTravel[]         @relation("UserTravelDepartureAirport")
  destinationForTravels     UserTravel[]         @relation("UserTravelDestinationAirport")
  departureForRepositions   AircraftReposition[] @relation("AircraftRepositionDepartureAirport")
  destinationForRepositions AircraftReposition[] @relation("AircraftRepositionDestinationAirport")

  @@map("airport")
}

model Runway {
  id              String @id @default(uuid()) @db.Uuid
  airportId       String @db.Uuid
  designator      String @db.VarChar(4)
  length          Int
  width           Int
  displace        Int?
  trueHeading     Int?
  magneticHeading Int
  elevation       Int?
  surfaceType     String @db.VarChar(16)
  lightingType    String @db.VarChar(16)
  coordinates     Json

  airport          Airport  @relation(fields: [airportId], references: [id], onDelete: Cascade)
  departureFlights Flight[] @relation("FlightDepartureRunway")
  arrivalFlights   Flight[] @relation("FlightArrivalRunway")

  @@map("runway")
}

model Terminal {
  id              String  @id @default(uuid()) @db.Uuid
  airportId       String  @db.Uuid
  shortName       String  @db.VarChar(8)
  fullName        String  @db.VarChar(128)
  averageTaxiTime Int
  operatorCodes   Json    @default("[]")
  text            String? @db.Text
  shape           Json?

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)
  gates   Gate[]

  @@map("terminal")
}

model Gate {
  id                String  @id @default(uuid()) @db.Uuid
  airportId         String  @db.Uuid
  terminalId        String  @db.Uuid
  name              String  @db.VarChar(16)
  category          String  @db.VarChar(32)
  parkingPositionId String? @db.Uuid

  terminal        Terminal         @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  parkingPosition ParkingPosition? @relation(fields: [parkingPositionId], references: [id], onDelete: SetNull)

  @@map("gate")
}

model ParkingPosition {
  id                        String  @id @default(uuid()) @db.Uuid
  airportId                 String  @db.Uuid
  terminalId                String  @db.Uuid
  name                      String  @db.VarChar(16)
  bridge                    String  @db.VarChar(32)
  stairs                    String  @db.VarChar(32)
  deicing                   String  @db.VarChar(32)
  deicingDescription        String? @db.Text
  gpu                       String  @db.VarChar(32)
  pca                       String  @db.VarChar(32)
  type                      String  @db.VarChar(32)
  spotType                  String  @db.VarChar(32)
  assistance                String  @db.VarChar(32)
  location                  String  @db.VarChar(32)
  noiseSensitivity          String  @db.VarChar(32)
  noiseSensitivityText      String? @db.Text
  noiseSensitivityStartTime String? @db.VarChar(5)
  noiseSensitivityEndTime   String? @db.VarChar(5)
  fuelingOptions            String  @db.VarChar(32)
  coordinates               Json?

  gates            Gate[]
  departureFlights Flight[]   @relation("FlightDepartureParkingPosition")
  arrivalFlights   Flight[]   @relation("FlightArrivalParkingPosition")
  lastSeenAircraft Aircraft[] @relation("AircraftLastParkingPosition")

  @@map("parking_position")
}

model Operator {
  id            String            @id @default(uuid()) @db.Uuid
  icaoCode      String            @db.VarChar(3)
  iataCode      String            @default("AA") @db.VarChar(2)
  shortName     String
  fullName      String
  callsign      String
  type          OperatorType      @default(legacy)
  hubs          Json              @default("[]")
  fleetSize     Int               @default(0)
  fleetTypes    Json              @default("[]")
  avgFleetAge   Float             @default(0)
  logoUrl       String?
  backgroundUrl String?
  continent     Continent         @default(europe)
  alliance      OperatorAlliance?
  group         OperatorGroup?

  aircrafts Aircraft[]
  flights   Flight[]
  rotations Rotation[]

  @@map("operator")
}

model Flight {
  id                         String         @id @default(uuid()) @db.Uuid
  flightNumber               String
  callsign                   String
  atcCallsign                String?
  status                     String
  aircraftId                 String         @db.Uuid
  timesheet                  Json
  loadsheets                 Json           @default("{\"final\": null, \"preliminary\": null}")
  operatorId                 String         @db.Uuid
  rotationId                 String?        @db.Uuid
  captainId                  String?        @db.Uuid
  source                     FlightSource   @default(manual)
  tracking                   FlightTracking @default(private)
  createdAt                  DateTime       @default(now())
  positionReports            Json           @default("[]")
  runwayAnalysis             String?
  ofpContent                 String?
  ofpDocumentUrl             String?
  simbriefRequestId          Int?
  simbriefSequenceId         String?
  isEtops                    Boolean        @default(false)
  greatCircleDistance        Int            @default(1)
  totalFuelBurned            Int            @default(1)
  route                      String?
  departureParkingPositionId String?        @db.Uuid
  departureRunwayId          String?        @db.Uuid
  arrivalParkingPositionId   String?        @db.Uuid
  arrivalRunwayId            String?        @db.Uuid
  isEmergencyDeclared        Boolean        @default(false)
  isDiversionDeclared        Boolean        @default(false)
  isPathAvailable            Boolean        @default(false)

  operator                 Operator               @relation(fields: [operatorId], references: [id])
  rotation                 Rotation?              @relation(fields: [rotationId], references: [id])
  captain                  User?                  @relation("FlightCaptain", fields: [captainId], references: [id])
  aircraft                 Aircraft               @relation(fields: [aircraftId], references: [id])
  airports                 AirportsOnFlights[]
  flightEvent              FlightEvent[]
  diversion                Diversion[]
  emergency                EmergencyDeclaration[]
  delayRequest             DelayRequest?
  userPerformingFlight     User[]                 @relation("UserCurrentFlight")
  departureParkingPosition ParkingPosition?       @relation("FlightDepartureParkingPosition", fields: [departureParkingPositionId], references: [id], onDelete: SetNull)
  departureRunway          Runway?                @relation("FlightDepartureRunway", fields: [departureRunwayId], references: [id], onDelete: SetNull)
  arrivalParkingPosition   ParkingPosition?       @relation("FlightArrivalParkingPosition", fields: [arrivalParkingPositionId], references: [id], onDelete: SetNull)
  arrivalRunway            Runway?                @relation("FlightArrivalRunway", fields: [arrivalRunwayId], references: [id], onDelete: SetNull)
  userTravels              UserTravel[]           @relation("UserTravelFlight")
  aircraftRepositions      AircraftReposition[]   @relation("AircraftRepositionFlight")

  @@map("flight")
}

model Diversion {
  id                         String   @id @default(uuid()) @db.Uuid
  reportedBy                 String   @db.Uuid
  reporterRole               String
  flightId                   String   @unique @db.Uuid
  airportId                  String   @db.Uuid
  decisionTime               DateTime
  estimatedTimeAtDestination DateTime
  reason                     String
  severity                   String
  position                   Json
  freeText                   String?
  notifySecurityOnGround     Boolean
  notifyMedicalOnGround      Boolean
  notifyFirefightersOnGround Boolean

  flight  Flight  @relation(fields: [flightId], references: [id])
  user    User    @relation(fields: [reportedBy], references: [id])
  airport Airport @relation(fields: [airportId], references: [id])

  @@map("flight_diversion")
}

model EmergencyDeclaration {
  id                    String    @id @default(uuid()) @db.Uuid
  flightId              String    @db.Uuid
  reportedBy            String    @db.Uuid
  urgency               String
  threatLevel           String
  category              String
  squawk                String?
  intention             String
  lastKnownPosition     Json?
  soulsOnBoard          Int
  fuelEnduranceMinutes  Int
  dangerousGoodsOnBoard String[]
  freeText              String
  declarationTime       DateTime  @default(now())
  resolvedAt            DateTime?
  resolvedBy            String?   @db.Uuid

  flight   Flight @relation(fields: [flightId], references: [id])
  reporter User   @relation("EmergencyReporter", fields: [reportedBy], references: [id])
  resolver User?  @relation("EmergencyResolver", fields: [resolvedBy], references: [id])

  @@index([flightId])
  @@map("flight_emergency")
}

model DelayRequest {
  id                String   @id @default(uuid()) @db.Uuid
  flightId          String   @unique @db.Uuid
  totalDelayMinutes Int
  createdAt         DateTime @default(now())

  flight  Flight        @relation(fields: [flightId], references: [id])
  reports DelayReport[]

  @@map("delay_request")
}

model DelayReport {
  id              String            @id @default(uuid()) @db.Uuid
  requestId       String            @db.Uuid
  delayMinutes    Int
  reasonCode      DelayReasonCode
  freeText        String?
  status          DelayReportStatus @default(pending)
  reportedById    String            @db.Uuid
  decidedById     String?           @db.Uuid
  rejectionReason String?
  decidedAt       DateTime?
  createdAt       DateTime          @default(now())

  request    DelayRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  reportedBy User         @relation("DelayReportReporter", fields: [reportedById], references: [id])
  decidedBy  User?        @relation("DelayReportDecider", fields: [decidedById], references: [id])

  @@index([requestId])
  @@index([status])
  @@map("delay_report")
}

model AirportsOnFlights {
  airportId   String @db.Uuid
  flightId    String @db.Uuid
  airportType String

  airport Airport @relation(fields: [airportId], references: [id])
  flight  Flight  @relation(fields: [flightId], references: [id])

  @@id([airportId, flightId])
  @@map("airport_flight")
}

model User {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String
  email                    String    @unique
  password                 String
  role                     UserRole
  pilotLicenseId           String?   @db.VarChar(8)
  currentFlightId          String?   @unique @db.Uuid
  currentRotationId        String?   @unique @db.Uuid
  simbriefUserId           String?
  totalFlightTime          Int       @default(0)
  totalGreatCircleDistance Int       @default(0)
  totalFuelBurned          Int       @default(0)
  homeAirportId            String?   @db.Uuid
  lastAirportId            String?   @db.Uuid
  lastAirportUpdatedAt     DateTime?

  homeAirport          Airport?               @relation("UserHomeAirport", fields: [homeAirportId], references: [id], onDelete: SetNull)
  lastAirport          Airport?               @relation("UserLastAirport", fields: [lastAirportId], references: [id], onDelete: SetNull)
  rotations            Rotation[]
  jwtRefreshToken      JwtRefreshToken[]
  currentFlight        Flight?                @relation("UserCurrentFlight", fields: [currentFlightId], references: [id])
  currentRotation      Rotation?              @relation(fields: [currentRotationId], references: [id], name: "CurrentRotation")
  flightEvent          FlightEvent[]
  diversion            Diversion[]
  emergenciesReported  EmergencyDeclaration[] @relation("EmergencyReporter")
  emergenciesResolved  EmergencyDeclaration[] @relation("EmergencyResolver")
  allFlights           Flight[]               @relation("FlightCaptain")
  delayReportsReported DelayReport[]          @relation("DelayReportReporter")
  delayReportsDecided  DelayReport[]          @relation("DelayReportDecider")
  travels              UserTravel[]

  @@map("user")
}

enum UserTravelType {
  performing_flight
  dead_head_manual
  dead_head_automatic

  @@map("user_travel_type")
}

enum UserTravelStatus {
  pending
  finished

  @@map("user_travel_status")
}

model UserTravel {
  id                   String           @id @default(uuid()) @db.Uuid
  userId               String           @db.Uuid
  type                 UserTravelType
  status               UserTravelStatus
  departureAirportId   String           @db.Uuid
  destinationAirportId String           @db.Uuid
  distance             Int
  flightId             String?          @db.Uuid
  createdAt            DateTime         @default(now())
  updatedAt            DateTime?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  departureAirport   Airport @relation("UserTravelDepartureAirport", fields: [departureAirportId], references: [id])
  destinationAirport Airport @relation("UserTravelDestinationAirport", fields: [destinationAirportId], references: [id])
  flight             Flight? @relation("UserTravelFlight", fields: [flightId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("user_travel")
}

enum AircraftRepositionType {
  performing_flight
  dead_head_manual
  dead_head_automatic

  @@map("aircraft_reposition_type")
}

enum AircraftRepositionStatus {
  pending
  finished

  @@map("aircraft_reposition_status")
}

model AircraftReposition {
  id                   String                   @id @default(uuid()) @db.Uuid
  aircraftId           String                   @db.Uuid
  type                 AircraftRepositionType
  status               AircraftRepositionStatus
  departureAirportId   String                   @db.Uuid
  destinationAirportId String                   @db.Uuid
  distance             Int
  flightId             String?                  @db.Uuid
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime?

  aircraft           Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  departureAirport   Airport  @relation("AircraftRepositionDepartureAirport", fields: [departureAirportId], references: [id])
  destinationAirport Airport  @relation("AircraftRepositionDestinationAirport", fields: [destinationAirportId], references: [id])
  flight             Flight?  @relation("AircraftRepositionFlight", fields: [flightId], references: [id], onDelete: SetNull)

  @@index([aircraftId])
  @@map("aircraft_reposition")
}

model Rotation {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  pilotId    String    @db.Uuid
  createdAt  DateTime  @default(now())
  updatedAt  DateTime?
  operatorId String?   @db.Uuid

  flights        Flight[]
  pilot          User      @relation(fields: [pilotId], references: [id])
  currentForUser User?     @relation("CurrentRotation")
  operator       Operator? @relation(fields: [operatorId], references: [id])

  @@map("rotation")
}

model JwtRefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  createdAt DateTime
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])

  @@map("jwt_refresh_token")
}

model FlightEvent {
  id        String           @id @default(uuid()) @db.Uuid
  scope     FlightEventScope
  type      String
  payload   Json             @default("{}")
  flightId  String           @db.Uuid
  actorId   String?          @db.Uuid
  createdAt DateTime         @default(now())

  flight Flight @relation(fields: [flightId], references: [id])
  actor  User?  @relation(fields: [actorId], references: [id])

  @@map("flight_event")
}

enum UserRole {
  CabinCrew
  Operations
  Admin
}

enum FlightEventScope {
  system
  operations
  user
}

enum DelayReasonCode {
  AMZ
  ATZ
  AMC
  RLL
  RLP
  RLS
  RLV
  ESR
  END
  ESM
  GBT
  GBJ
  GBS
  ODI
  ORA
  ORO
  OFL
  OAD
  OSM
  OTH

  @@map("delay_reason_code")
}

enum DelayReportStatus {
  pending
  accepted
  rejected

  @@map("delay_report_status")
}

enum Continent {
  africa
  asia
  europe
  north_america
  south_america
  oceania
}

enum AircraftState {
  idle
  planned
  checked_in
  cruise
}

enum FlightSource {
  manual
  simbrief
}

enum FlightTracking {
  public
  private
  disabled
}

enum OperatorType {
  legacy
  low_cost
  charter
  government_military
}

enum OperatorAlliance {
  star_alliance
  sky_team
  oneworld
  vanilla_alliance
}

enum OperatorGroup {
  lufthansa_group
  international_airlines_group
  air_france_klm
  ryanair_holdings
  easyjet_group
  ana_holdings
  japan_airlines_group
  qantas_group
  singapore_airlines_group
  alaska_air_group
  hna_aviation_group
  china_southern_air_holding
  china_eastern_air_holding
  air_china_group
  korean_air_group
  turkish_airlines_group
  emirates_group
}
