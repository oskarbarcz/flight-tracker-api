{
  "name": "flight-tracker-api",
  "version": "1.41.0",
  "private": true,
  "homepage": "https://flights.barcz.me",
  "author": "oskarbarcz",
  "license": "Unlicense",
  "description": "A comprehensive web app for scheduling and tracking flights in a flight simulator environment. Designed for virtual aviation enthusiasts, it enables seamless management of flights, aircraft, airports, crews, and passengers.",
  "scripts": {
    "build": "npx nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "format": "prettier .",
    "format:fix": "prettier --write .",
    "lint": "eslint '{src,features,prisma,test}/**/*.ts'",
    "lint:fix": "eslint '{src,features,prisma,test}/**/*.ts' --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:functional": "npx cucumber-js",
    "database:reset": "npx prisma db push --force-reset",
    "database:seed": "npx prisma db push --force-reset && npx prisma db seed",
    "database:migrate": "npx prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.18.0",
    "axios": "^1.13.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-gherkin": "^3.1.3",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed/seed.ts"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "hono": "^4.11.7",
    "lodash": "^4.17.23",
    "multer": "^2.0.3",
    "serialize-javascript": "^7.0.3",
    "@angular-devkit/core": {
      "ajv": "^8.18.0"
    },
    "@nestjs/schematics": {
      "ajv": "^8.18.0"
    }
  }
}
